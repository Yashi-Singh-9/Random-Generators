@import url('https://fonts.googleapis.com/css2?family=Epilogue:wght@600;700&display=swap')

*
    margin 0
    padding 0
    box-sizing border-box

body 
    background url(images/background-image.jpeg) no-repeat
    background-size cover
    min-height 88vh
    font-family: 'Epilogue', sans-serif !important

main 
    margin-top 6rem
    max-width 700px
    width 95%

    h1
        background-color darken(#BDD1D2, 20%)
        color darken(#767477, 55%)

    .info
        background-color darken(#BACAC0, 20%)

        h3,
        button,
        h5
            color darken(#A78F69, 70%)

        button 
            font-size 1.125rem
            background-color lighten(#D8CCB4, 30%)
            transition 0.3s ease

            &:hover
                background-color darken(#D8CCB4, 10%)
